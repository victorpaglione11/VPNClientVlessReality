<Window x:Class="XrayGUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="XrayBox"
        Width="320"
        Height="520"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>

        <Style x:Key="ModernButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#007ACC"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>

            <Setter Property="Template">
                <Setter.Value>

                    <ControlTemplate TargetType="Button">

                        <Border x:Name="Border"
                                CornerRadius="22"
                                Background="{TemplateBinding Background}">

                            <ContentPresenter
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"/>

                        </Border>

                        <ControlTemplate.Triggers>

                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border"
                                        Property="Background"
                                        Value="#1793E8"/>
                            </Trigger>

                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Border"
                                        Property="Background"
                                        Value="#0062A8"/>
                            </Trigger>

                        </ControlTemplate.Triggers>

                    </ControlTemplate>

                </Setter.Value>
            </Setter>

        </Style>

    </Window.Resources>

    <Border
        CornerRadius="14"
        Background="#1B1B1B"
        BorderBrush="#303030"
        BorderThickness="1">

        <Grid>

            <Grid.RowDefinitions>
                <RowDefinition Height="36"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="80"/>
            </Grid.RowDefinitions>

            <!-- Barra Superior -->

            <Border Grid.Row="0"
                    Background="#252525"
                    CornerRadius="14,14,0,0"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">

                <Grid>

                    <Grid.ColumnDefinitions>

                        <ColumnDefinition/>

                        <ColumnDefinition Width="40"/>

                    </Grid.ColumnDefinitions>

                    <TextBlock
                        Margin="12,0"
                        VerticalAlignment="Center"
                        FontWeight="Bold"
                        FontSize="14"
                        Foreground="White"
                        Text="XrayBox"/>

                    <Button
                        Grid.Column="1"
                        Click="Close_Click"
                        Background="Transparent"
                        BorderThickness="0"
                        Foreground="White"
                        FontSize="14"
                        Content="✕"
                        Cursor="Hand"/>

                </Grid>

            </Border>

            <!-- Conteúdo -->

            <StackPanel
                Grid.Row="1"
                VerticalAlignment="Center"
                HorizontalAlignment="Center">

                <Grid>

                    <Ellipse
                        x:Name="ConnectionIndicator"
                        Width="130"
                        Height="130"
                        Fill="#2B2B2B"
                        Stroke="#404040"
                        StrokeThickness="3">

                        <Ellipse.Effect>

                            <DropShadowEffect
                                BlurRadius="15"
                                ShadowDepth="0"
                                Opacity="0.35"/>

                        </Ellipse.Effect>

                    </Ellipse>

                    <TextBlock
                        x:Name="StatusSymbol"
                        Text="⏻"
                        FontSize="60"
                        Foreground="#8A8A8A"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"/>

                </Grid>

                <TextBlock
                    x:Name="StatusText"
                    Margin="0,25,0,0"
                    FontSize="21"
                    FontWeight="SemiBold"
                    Foreground="White"
                    Text="Desconectado"
                    HorizontalAlignment="Center"/>

            </StackPanel>

            <!-- Botão -->

            <Grid Grid.Row="1"
                  Margin="0,322,0,0">

                <Button
                    x:Name="BtOpenQr"
                    Height="45"
                    Width="270"
                    Click="BtOpenQr_Click"
                    Style="{StaticResource ModernButtonStyle}"
                    Content="Abrir QR Code">

                    <Button.Effect>

                        <DropShadowEffect
                            BlurRadius="12"
                            ShadowDepth="3"
                            Opacity="0.35"/>

                    </Button.Effect>

                </Button>

            </Grid>

        </Grid>

    </Border>

</Window>